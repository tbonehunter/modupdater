# .gitignore - SMAPI Mod Updater

# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
*.egg

# Build output (keep dist/*.zip for distribution, ignore intermediates)
dist/SMAPIModUpdater/

# GitHub Actions (not used)
.github/

# Local-only directories
.DoNotUse/

# Config (user-specific paths)
smapi_updater_config.json

# Session log (regenerated each run)
smapi_updater_log.txt
SMAPI-latest.txt

# Virtual environments
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
._*
